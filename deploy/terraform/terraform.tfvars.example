aws_region = "us-east-1"
name_prefix = "peregrine"
environment = "prod"

# Existing network and DNS
vpc_id             = "vpc-xxxxxxxx"
public_subnet_ids  = ["subnet-public-a", "subnet-public-b"]
private_subnet_ids = ["subnet-private-a", "subnet-private-b"]
route53_zone_id    = "ZXXXXXXXXXXXXX"
domain_name        = "example.com"
frontend_subdomain = "peregrine"
api_subdomain      = "peregrine-api"
acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Create this in Secrets Manager first (plain string value)
auth_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:peregrine-auth-secret-xxxxx"
auth_email_sender = "no-reply@example.com"
auth_email_region = "us-east-1"
auth_mfa_issuer   = "Acquittify"
ses_sender_identity_arn = "arn:aws:ses:us-east-1:123456789012:identity/example.com"

# Optional S3 settings
s3_bucket_name         = ""
s3_force_destroy       = false
s3_versioning_enabled  = false
s3_kms_key_arn         = ""
s3_cors_allowed_origins = ["https://peregrine.example.com", "https://www.peregrine.example.com"]

# Optional secret ARNs
dropbox_access_token_secret_arn = ""
dropbox_refresh_token_secret_arn = ""
dropbox_app_key_secret_arn = ""
dropbox_app_secret_secret_arn = ""
dropbox_team_member_id_secret_arn = ""
openai_api_key_secret_arn = ""
llm_api_key_secret_arn = ""
courtlistener_api_token_secret_arn = ""

# LLM/OpenClaw provider config
llm_model = "openclaw"
agent_model = "openclaw"
openclaw_agent_id = "main"
llm_base_url = ""

# Optional app overrides
cors_allow_origins = ["https://peregrine.example.com", "https://www.peregrine.example.com"]
cookie_domain      = ".example.com"
frontend_next_public_api_url = "https://peregrine-api.example.com"

# Optional image tags (ECR repos are created by Terraform)
api_image_tag      = "latest"
worker_image_tag   = "latest"
frontend_image_tag = "latest"

# Caselaw ingest scheduler (EventBridge -> ECS task)
caselaw_scheduler_enabled = true
caselaw_schedule_expression = "rate(30 minutes)"
caselaw_schedule_timezone = "America/Detroit"
caselaw_task_cpu = 1024
caselaw_task_memory = 2048
caselaw_job_max_runtime_hours = 0.33
caselaw_job_backfill_start_date = "2011-01-01"
caselaw_job_max_court_date_queries = 120
caselaw_job_page_size = 40
caselaw_job_max_pages_per_query = 20
caselaw_job_request_timeout_seconds = 30
caselaw_job_request_pause_seconds = 0.1
caselaw_job_request_retries = 5
caselaw_job_include_quasi_criminal = true
caselaw_job_only_courts = ""
