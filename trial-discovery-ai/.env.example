# Project
COMPOSE_PROJECT_NAME=trial-discovery-ai
ENVIRONMENT=local

# -----------------------------
# Postgres (metadata + audit + pgvector)
# -----------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trialai
POSTGRES_USER=trialai
POSTGRES_PASSWORD=trialai_password_change_me

# Recommended connection string for your FastAPI backend:
# (your backend should build DATABASE_URL from the pieces below)
DATABASE_URL=postgresql+psycopg://trialai:trialai_password_change_me@localhost:5432/trialai

# -----------------------------
# Redis (Celery broker + caching)
# -----------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# -----------------------------
# MinIO (S3-compatible artifact store)
# - store derived artifacts: page images, extracted text JSON, thumbnails, email JSON
# -----------------------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_password_change_me

MINIO_BUCKET=trialai-artifacts

# What your backend should use (inside Docker network vs local dev):
# - If backend runs on host (VS Code local): use localhost
S3_ENDPOINT_URL=http://localhost:9000

# - If backend runs as a container in this same compose network: use http://minio:9000
S3_INTERNAL_ENDPOINT_URL=http://minio:9000

S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin_password_change_me
S3_REGION=us-east-1
S3_SECURE=false

# -----------------------------
# Optional tools
# -----------------------------
ADMINER_PORT=8080

# -----------------------------
# Dropbox (source of truth)
# -----------------------------
DROPBOX_CASE_ROOT_PATH=https://www.dropbox.com/scl/fo/<shared_folder_id>/<token>
DROPBOX_ACCESS_TOKEN=your_dropbox_access_token
# Optional: use refresh tokens instead of long-lived access tokens
DROPBOX_REFRESH_TOKEN=your_dropbox_refresh_token
DROPBOX_APP_KEY=your_dropbox_app_key
DROPBOX_APP_SECRET=your_dropbox_app_secret
DROPBOX_TEAM_MEMBER_ID=your_team_member_id

# -----------------------------
# Embeddings (OpenAI)
# -----------------------------
OPENAI_API_KEY=your_openai_api_key

# -----------------------------
# Local LLM / Embeddings (OpenAI-compatible)
# -----------------------------
# Example for local Qwen32B served with an OpenAI-compatible server (vLLM/LM Studio):
# LLM_BASE_URL=http://localhost:8004/v1
# LLM_API_KEY=local
# LLM_MODEL=qwen2.5-32b-instruct
# AGENT_MODEL=openclaw
# OPENCLAW_AGENT_ID=main
# LLM_REPAIR_MODEL=qwen2.5-32b-instruct
# EMBEDDING_BASE_URL=http://localhost:8004/v1
# EMBEDDING_API_KEY=local
# EMBEDDING_MODEL=bge-large-en
# EMBEDDING_DIM=768

# -----------------------------
# Frontend API
# -----------------------------
NEXT_PUBLIC_PEREGRINE_API_URL=http://localhost:8002
NEXT_PUBLIC_PEREGRINE_CSRF_COOKIE_NAME=peregrine_csrf
NEXT_PUBLIC_PEREGRINE_CSRF_HEADER_NAME=X-CSRF-Token

# -----------------------------
# API runtime
# -----------------------------
CORS_ALLOW_ORIGINS=http://localhost:3000
UVICORN_WORKERS=2
CELERY_CONCURRENCY=2
CELERY_LOG_LEVEL=info

# -----------------------------
# Auth (session cookie JWT)
# -----------------------------
AUTH_SECRET_KEY=replace_with_long_random_secret
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXP_MINUTES=720
AUTH_COOKIE_NAME=peregrine_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_CSRF_COOKIE_NAME=peregrine_csrf
AUTH_CSRF_HEADER_NAME=X-CSRF-Token
AUTH_PASSWORD_RESET_TOKEN_EXP_MINUTES=30
AUTH_PASSWORD_RESET_CODE_LENGTH=6
AUTH_PASSWORD_RESET_DEV_RETURN_TOKEN=false
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_REQUIRE_UPPER=true
AUTH_PASSWORD_REQUIRE_LOWER=true
AUTH_PASSWORD_REQUIRE_NUMBER=true
AUTH_PASSWORD_REQUIRE_SYMBOL=true
AUTH_EMAIL_SENDER=no-reply@acquittify.ai
AUTH_EMAIL_REGION=us-east-1
AUTH_MFA_ISSUER=Acquittify
AUTH_MFA_CHALLENGE_EXP_MINUTES=10
AUTH_MFA_CHALLENGE_MAX_ATTEMPTS=5
AUTH_MFA_BACKUP_CODE_COUNT=8
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_BACKEND=memory
AUTH_RATE_LIMIT_PATHS=/auth/login,/auth/register,/auth/password/forgot,/auth/password/reset,/auth/mfa/login/verify
# AUTH_COOKIE_DOMAIN=
