.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/
venv.bak/
.env

# Pytest
.pytest_cache/

# MyPy
.mypy_cache/

# Editor directories and files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# macOS
.DS_Store

# Logs and databases
*.log
*.sqlite3

# Ignore Chroma DB persistence and processed corpus outputs
Corpus/Chroma/
Corpus/Processed/

# Ignore large model downloads
models/

# Keep source code folders named "models" or "lib" under trial-discovery-ai.
!trial-discovery-ai/backend/app/db/models/
!trial-discovery-ai/backend/app/db/models/*.py
!trial-discovery-ai/frontend/src/lib/
!trial-discovery-ai/frontend/src/lib/api.ts

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
*.tfvars.json
.terraform.lock.hcl

# Acquittify corpora / local data mounts (intentionally external to git)
acquittify-data/
Corpus/
Obsidian/
Acquittify Storage/
finetune/
Casefiles/
data/transcripts/
_archived_apps/

# Dependency and build outputs
**/node_modules/
**/.next/

# Virtual environments and local Python caches
.venv-incourt/
.venv*/
**/__pycache__/

# Local runtime state
ingestion_state.json

# Terraform local plans
deploy/terraform/tfplan*

# Local run artifacts
reports/*.err
reports/*.out
reports/ingest_CAP_log.jsonl
reports/caselaw_nightly_ingest.jsonl
reports/caselaw_archive_backfill.jsonl

# TypeScript incremental cache
**/*.tsbuildinfo
