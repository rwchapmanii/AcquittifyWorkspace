# Project
COMPOSE_PROJECT_NAME=trial-discovery-ai
ENVIRONMENT=local

# -----------------------------
# External data roots (keep corpus outside repo)
# -----------------------------
ACQUITTIFY_DATA_ROOT=~/AcquittifyData
ACQUITTIFY_CORPUS_ROOT=~/AcquittifyData/Corpus
CHROMA_DIR=~/AcquittifyData/Corpus/Chroma
ACQUITTIFY_DATASET_DIR=~/AcquittifyData/acquittify-data
ACQUITTIFY_OBSIDIAN_ROOT=~/AcquittifyData/Obsidian
ACQUITTIFY_PRECEDENT_VAULT_ROOT=~/AcquittifyData/Obsidian/Ontology/precedent_vault

# -----------------------------
# Postgres (metadata + audit + pgvector)
# -----------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trialai
POSTGRES_USER=trialai
POSTGRES_PASSWORD=trialai_password_change_me

# Recommended connection string for your FastAPI backend:
# (your backend should build DATABASE_URL from the pieces below)
DATABASE_URL=postgresql+psycopg://trialai:<POSTGRES_PASSWORD>@localhost:5432/trialai

# -----------------------------
# Redis (Celery broker + caching)
# -----------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# -----------------------------
# MinIO (S3-compatible artifact store)
# - store derived artifacts: page images, extracted text JSON, thumbnails, email JSON
# -----------------------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MINIO_ROOT_USER=<MINIO_ROOT_USER>
MINIO_ROOT_PASSWORD=<MINIO_ROOT_PASSWORD>

MINIO_BUCKET=trialai-artifacts

# What your backend should use (inside Docker network vs local dev):
# - If backend runs on host (VS Code local): use localhost
S3_ENDPOINT_URL=http://localhost:9000

# - If backend runs as a container in this same compose network: use http://minio:9000
S3_INTERNAL_ENDPOINT_URL=http://minio:9000

S3_ACCESS_KEY_ID=<S3_ACCESS_KEY_ID>
S3_SECRET_ACCESS_KEY=<S3_SECRET_ACCESS_KEY>
S3_REGION=us-east-1
S3_SECURE=false

# -----------------------------
# Optional tools
# -----------------------------
ADMINER_PORT=8080

# -----------------------------
# Local LLM / Embeddings (OpenAI-compatible)
# -----------------------------
# Example for local Qwen32B served with an OpenAI-compatible server (vLLM/LM Studio):
# LLM_BASE_URL=http://localhost:8004/v1
# LLM_API_KEY=local
# LLM_MODEL=qwen2.5-32b-instruct
# LLM_REPAIR_MODEL=qwen2.5-32b-instruct
# EMBEDDING_BASE_URL=http://localhost:8004/v1
# EMBEDDING_API_KEY=local
# EMBEDDING_MODEL=bge-large-en
# EMBEDDING_DIM=768

# -----------------------------
# Ontology compiler
# -----------------------------
ACQ_ONTOLOGY_VAULT_ROOT=Obsidian/precedent_vault
ACQ_COURTLISTENER_CITATION_LOOKUP_URL=https://www.courtlistener.com/api/rest/v4/citation-lookup/
ACQ_COURTLISTENER_API_TOKEN=
ACQ_CITATION_CACHE_PATH=acquittify-data/cache/citation_resolution.sqlite
ACQ_ONTOLOGY_REQUEST_TIMEOUT=20
ACQ_ONTOLOGY_RESOLVER_ENABLED=1

# -----------------------------
# Nightly federal criminal caselaw ingest (CourtListener)
# -----------------------------
ACQ_CASELAW_DB_DSN=postgresql://acquittify:<DB_PASSWORD>@localhost:5432/courtlistener
COURTLISTENER_API_TOKEN=
ACQ_CASELAW_RUNTIME_HOURS=6
ACQ_CASELAW_TIMEZONE=America/Detroit
ACQ_CASELAW_STATE_KEY=courtlistener_federal_criminal_nightly
ACQ_CASELAW_BACKFILL_START_DATE=
ACQ_CASELAW_ONLY_COURTS=
ACQ_CASELAW_LOG_PATH=reports/caselaw_nightly_ingest.jsonl
ACQ_CASELAW_REQUEST_RETRIES=5
ACQ_CASELAW_MAX_COURT_DATE_QUERIES=0
ACQ_CASELAW_PYTHON=python3
ACQ_CASELAW_ARCHIVE_CASES_DIR=_archived_apps/acquittify_20260303_131259/acquittifystorage/corpus/cases/Federal Criminal Cases
ACQ_CASELAW_ARCHIVE_LOG_PATH=reports/caselaw_archive_backfill.jsonl

# -----------------------------
# API runtime
# -----------------------------
CORS_ALLOW_ORIGINS=http://localhost:3000
UVICORN_WORKERS=2
CELERY_CONCURRENCY=2
CELERY_LOG_LEVEL=info
AUTH_RATE_LIMIT_BACKEND=memory

# -----------------------------
# WhatsApp channel (Electron webhook)
# -----------------------------
ACQUITTIFY_WHATSAPP_ENABLED=0
ACQUITTIFY_WHATSAPP_BIND_HOST=127.0.0.1
ACQUITTIFY_WHATSAPP_PORT=8788
ACQUITTIFY_WHATSAPP_PUBLIC_URL=
ACQUITTIFY_WHATSAPP_VALIDATE_SIGNATURE=1
ACQUITTIFY_WHATSAPP_AUTH_TOKEN=
ACQUITTIFY_WHATSAPP_DEFAULT_MODE=casefile
ACQUITTIFY_WHATSAPP_ALLOWED_NUMBERS=
ACQUITTIFY_WHATSAPP_ENFORCE_ALLOWLIST=0
ACQUITTIFY_WHATSAPP_MAX_DOC_EXCERPT_CHARS=1200
