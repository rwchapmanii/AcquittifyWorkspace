{
  "name": "acquittifyelectron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check:syntax": "node --check main.js && node --check preload.js && node --check ui/app.js",
    "check:ontology-graph-lock": "node ./scripts/check-ontology-graph-lock.js",
    "check:ontology-graph-lock:update": "node ./scripts/check-ontology-graph-lock.js --update",
    "check:pdf-layout": "node ./scripts/verify-pdf-layout-contract.js",
    "check:ui-smoke": "node ./scripts/smoke-ui-contract.js",
    "check:ontology-filters": "node ./scripts/verify-ontology-filters.js",
    "test:smoke": "npm run check:syntax && npm run check:ontology-graph-lock && npm run check:pdf-layout && npm run check:ui-smoke",
    "build": "npm run check:ontology-graph-lock && npm run check:pdf-layout && electron-builder"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.acquittify.app",
    "productName": "Acquittify",
    "icon": "../assets/app_icon.icns",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "../assets/app_icon.icns",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Acquittify uses the microphone for live courtroom transcription."
      }
    }
  },
  "dependencies": {
    "@kenjiuno/msgreader": "^1.28.0",
    "golden-layout": "^2.6.0",
    "js-yaml": "^4.1.1",
    "mailparser": "^3.9.3",
    "mammoth": "^1.11.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^3.11.174",
    "tslib": "^2.8.1",
    "vis-network": "^10.0.2",
    "xlsx": "^0.18.5"
  }
}
